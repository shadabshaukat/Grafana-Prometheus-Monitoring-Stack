# ==========================
# Observability Stack Config
# ==========================

ENV_NAME=dev

# Base path where generated configs/data are stored
BASE_DIR=/opt/observability-stack

# --------------------------
# Container images
# --------------------------
NGINX_IMAGE=nginx:stable-alpine
GRAFANA_IMAGE=grafana/grafana-oss:latest
PROM_IMAGE=prom/prometheus:latest
PG_EXPORTER_IMAGE=prometheuscommunity/postgres-exporter:latest

# --------------------------
# Container names
# --------------------------
NGINX_CONTAINER_NAME=nginx-grafana
GRAFANA_CONTAINER_NAME=grafana
PROM_CONTAINER_NAME=prometheus

# --------------------------
# Networking/ports
# --------------------------
NGINX_BIND_ADDRESS=0.0.0.0
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=8443

PROM_BIND_ADDRESS=127.0.0.1
PROM_PORT=9090
PROM_SCRAPE_INTERVAL=15s
# Optional path to extra Prometheus scrape jobs YAML fragment
# Example: /opt/observability-stack/prometheus/extra-scrape-config.yml
PROM_ADDITIONAL_SCRAPE_CONFIG=

GRAFANA_INTERNAL_PORT=3000

# --------------------------
# Grafana settings
# --------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=ChangeThisNow!StrongPass123
GRAFANA_ALLOW_SIGNUP=false
GRAFANA_COOKIE_SECURE=true
GRAFANA_COOKIE_SAMESITE=strict
GRAFANA_INSTALL_PLUGINS=
# Enable auto-install of OCI datasource plugins into Grafana
ENABLE_OCI_PLUGINS=true
# OCI Grafana plugin IDs (comma-safe, merged into GF_INSTALL_PLUGINS)
OCI_METRICS_PLUGIN_ID=oci-metrics-datasource
OCI_LOGS_PLUGIN_ID=oci-logs-datasource

GRAFANA_DS_NAME=Prometheus
GRAFANA_DS_UID=prometheus

# --------------------------
# Exporter fleet
# --------------------------
# Number of exporter services to create in compose
EXPORTER_COUNT=2

# Prometheus scrape targets (comma-separated)
EXPORTER_TARGETS=postgres_exporter_primary:9187,postgres_exporter_reporting:9187

# Exporter service names + DSNs
EXPORTER_1_NAME=postgres_exporter_primary
EXPORTER_1_DSN=postgresql://monitor_user:REPLACE_ME@10.10.1.82:5432/postgres?sslmode=require

EXPORTER_2_NAME=postgres_exporter_reporting
EXPORTER_2_DSN=postgresql://monitor_user:REPLACE_ME@10.10.1.83:5432/postgres?sslmode=require

# Add more exporters by increasing EXPORTER_COUNT and adding EXPORTER_N_NAME / EXPORTER_N_DSN
# Example:
# EXPORTER_3_NAME=postgres_exporter_analytics
# EXPORTER_3_DSN=postgresql://monitor_user:REPLACE_ME@10.10.1.84:5432/postgres?sslmode=require

# --------------------------
# Certificate defaults
# --------------------------
CERT_DAYS=365
CERT_COUNTRY=AU
CERT_STATE=NSW
CERT_LOCALITY=Sydney
CERT_ORG=Observability
CERT_OU=Platform
CERT_CN=grafana.local

# --------------------------
# OS behavior
# --------------------------
ENABLE_CHOWN=true
ENABLE_FIREWALL=true
# auto | firewalld | ufw | none
FIREWALL_BACKEND=auto

# Run smoke tests automatically at end of deploy
RUN_SMOKE_TEST_AFTER_DEPLOY=true

# Run Grafana dashboard datasource-binding checker after deploy
RUN_GRAFANA_BINDING_CHECK_AFTER_DEPLOY=true
GRAFANA_UNIFIED_DASH_UID=postgresql-unified-insights
# Optional override; empty => https://${LOCAL_TEST_HOST}:${NGINX_HTTPS_PORT}
GRAFANA_API_BASE_URL=

# Health-check retry tuning (helps avoid startup race/502 during first boot)
HEALTHCHECK_MAX_RETRIES=30
HEALTHCHECK_SLEEP_SECONDS=2
